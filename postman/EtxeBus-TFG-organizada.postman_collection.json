{
  "info": {
    "name": "EtxeBus TFG - Coleccion Organizada",
    "description": "Coleccion manual para memoria y defensa del TFG, organizada por servicio y por casos de error.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "users_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "transport_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "usuario_id",
      "value": "1"
    },
    {
      "key": "linea_id",
      "value": "1"
    },
    {
      "key": "parada_id",
      "value": "1"
    },
    {
      "key": "trayecto_id",
      "value": "1"
    },
    {
      "key": "favorito_id",
      "value": "1"
    },
    {
      "key": "horario_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health checks",
      "item": [
        {
          "name": "Gateway - GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/health",
            "description": "Esperado: 200 con status ok."
          }
        },
        {
          "name": "Gateway - GET /health/dependencies",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/health/dependencies",
            "description": "Esperado: 200 si usuarios/transporte responden OK; 502 si hay dependencia caida."
          }
        },
        {
          "name": "Usuarios - GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{users_url}}/health",
            "description": "Esperado: 200 con status ok."
          }
        },
        {
          "name": "Transporte - GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{transport_url}}/health",
            "description": "Esperado: 200 con status ok."
          }
        }
      ]
    },
    {
      "name": "Gateway",
      "item": [
        {
          "name": "POST /usuarios/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ainara@example.com\",\n  \"contrasenia\": \"secret123\"\n}"
            },
            "url": "{{gateway_url}}/usuarios/login"
          }
        },
        {
          "name": "POST /usuarios/logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": {{usuario_id}}\n}"
            },
            "url": "{{gateway_url}}/usuarios/logout"
          }
        },
        {
          "name": "GET /usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/usuarios"
          }
        },
        {
          "name": "GET /favoritos?idUsuario=",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/favoritos?idUsuario={{usuario_id}}"
          }
        },
        {
          "name": "POST /favoritos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": {{usuario_id}},\n  \"tipo\": \"trayecto\",\n  \"origin_slug\": \"metro\",\n  \"destination_slug\": \"santa-marina\",\n  \"origin_label\": \"Metro\",\n  \"destination_label\": \"Santa Marina\"\n}"
            },
            "url": "{{gateway_url}}/favoritos"
          }
        },
        {
          "name": "GET /lineas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/lineas"
          }
        },
        {
          "name": "GET /paradas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/paradas"
          }
        },
        {
          "name": "GET /trayectos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/trayectos"
          }
        },
        {
          "name": "GET /horarios/publicados",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/horarios/publicados"
          }
        },
        {
          "name": "GET /metro/etxebarri",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/metro/etxebarri?limit=5"
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ainara@example.com\",\n  \"contrasenia\": \"secret123\"\n}"
            },
            "url": "{{users_url}}/auth/login"
          }
        },
        {
          "name": "GET /usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{users_url}}/usuarios"
          }
        },
        {
          "name": "POST /usuarios",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": 1001,\n  \"nomUsuario\": \"usuario_demo\",\n  \"email\": \"usuario_demo@example.com\",\n  \"contrasenia\": \"secret123\"\n}"
            },
            "url": "{{users_url}}/usuarios"
          }
        },
        {
          "name": "GET /usuarios/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{users_url}}/usuarios/{{usuario_id}}"
          }
        },
        {
          "name": "GET /favoritos?idUsuario=",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{users_url}}/favoritos?idUsuario={{usuario_id}}"
          }
        }
      ]
    },
    {
      "name": "Transporte",
      "item": [
        {
          "name": "GET /lineas/",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{transport_url}}/lineas/"
          }
        },
        {
          "name": "POST /lineas/",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"linea-demo\",\n  \"nomLinea\": \"Linea Demo\",\n  \"badge\": \"LD\",\n  \"subtitle\": \"Servicio demo\",\n  \"info\": \"Linea para pruebas\",\n  \"color\": \"#1256A0\",\n  \"orden\": 99\n}"
            },
            "url": "{{transport_url}}/lineas/"
          }
        },
        {
          "name": "POST /paradas/",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Parada Demo\",\n  \"coordX\": 43.25,\n  \"coordY\": -2.9,\n  \"idLinea\": {{linea_id}},\n  \"orden\": 1\n}"
            },
            "url": "{{transport_url}}/paradas/"
          }
        },
        {
          "name": "POST /trayectos/",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idOrigen\": {{parada_id}},\n  \"idDestino\": {{parada_id}},\n  \"duracionEstm\": 10.5\n}"
            },
            "url": "{{transport_url}}/trayectos/"
          }
        },
        {
          "name": "GET /horarios/publicados",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{transport_url}}/horarios/publicados"
          }
        },
        {
          "name": "POST /favoritos/",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"ainara\",\n  \"contrasenia\": \"secret123\",\n  \"origin_slug\": \"metro\",\n  \"destination_slug\": \"santa-marina\",\n  \"origin_label\": \"Metro\",\n  \"destination_label\": \"Santa Marina\"\n}"
            },
            "url": "{{transport_url}}/favoritos/"
          }
        }
      ]
    },
    {
      "name": "Errores",
      "item": [
        {
          "name": "400 - Usuarios id invalido",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{users_url}}/usuarios/abc"
          }
        },
        {
          "name": "401 - Login invalido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ainara@example.com\",\n  \"contrasenia\": \"incorrecta\"\n}"
            },
            "url": "{{gateway_url}}/usuarios/login"
          }
        },
        {
          "name": "404 - Ruta inexistente en gateway",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/no-existe"
          }
        },
        {
          "name": "502 - Dependencias caidas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gateway_url}}/health/dependencies"
          }
        }
      ]
    }
  ]
}
